---
import type { GetStaticPaths, Page } from 'astro'
import { Collapse } from 'astro-pure/user'
import { Paginator } from 'astro-pure/components/pages'
import config from 'virtual:config'
import PageLayout from '@/layouts/CommonPage.astro'
import FriendList from '@/components/links/FriendList.astro'
import FriendBadgeLegend from '@/components/links/FriendBadgeLegend.astro'
import { links, specialLinks } from '@/links-config'
import type { LinkItem } from '@/links-config'

export const prerender = true

export const getStaticPaths = (({ paginate }) => {
  const commonLinks = links.filter(link => !link.disconnected)
  return paginate(commonLinks, { pageSize: 12 })
}) satisfies GetStaticPaths

interface Props {
  page: Page<LinkItem>
}

const { page } = Astro.props

const headings = [
  { depth: 2, slug: 'common-links', text: 'Common Links' },
  { depth: 2, slug: 'special-links', text: 'Special Links' },
  { depth: 2, slug: 'apply-links', text: 'Apply Links' }
]

const linksConf = config.integ.links

// Common 友链：一个列表（全部在 common 中），失联的单独折叠
// const commonLinks = links.filter(link => !link.disconnected) // Replaced by page.data
const disconnectedLinks = links.filter(link => link.disconnected)

const paginationProps = {
  ...(page.url.prev && {
    prevUrl: {
      text: `← Previous`,
      url: page.url.prev
    }
  }),
  ...(page.url.next && {
    nextUrl: {
      text: `Next →`,
      url: page.url.next
    }
  })
}
---

<PageLayout title='Links' {headings} comment commentPath='/links/'>
  <h2 id='common-links'>Common Links</h2>
  <FriendList links={page.data} />
  
  <Paginator {...paginationProps} />

  {
    disconnectedLinks.length > 0 && (
      <Collapse title='Links with Bad Status'>
        <FriendList links={disconnectedLinks} />
      </Collapse>
    )
  }
  <Collapse title='Imprint Legend'>
    <FriendBadgeLegend />
  </Collapse>
  <h2 id='special-links'>Special Links</h2>
  {
    specialLinks.length > 0 ? (
      <FriendList links={specialLinks} isSpecial={true} />
    ) : (
      <p>Special links will be displayed here.</p>
    )
  }

  <h2 id='apply-links'>Apply Links</h2>
  <p>本站信息（点击复制）The site information (click to copy)：</p>
  <blockquote class='not-prose grid grid-cols-[auto_1fr] gap-x-2 break-words border-s-4 ps-4'>
    {
      linksConf.applyTip.map(({ name, val }) => {
        const script = `navigator.clipboard.writeText('${val}');document.dispatchEvent(new CustomEvent('toast',{detail:{message:'Copied "${val}" to clipboard!'}}))`
        return (
          <>
            <span class='text-end'>{name}:</span>
            <samp class='cursor-pointer font-sans font-normal' onclick={script}>
              {val}
            </samp>
          </>
        )
      })
    }
  </blockquote>

  <p>
    可通过下方留言或
    <a href={config.footer.social?.email?.url ?? '#'} class='underline'>
      发送邮件
    </a>
    申请友链。申请说明：<br />
    Apply your link by leaving a comment or
    <a href={config.footer.social?.email?.url ?? '#'} class='underline'>
      sending an email
    </a>
    . Additional info:
  </p>
  <ul>
    <li>推荐了本站 You've recommended our link on your website</li>
    <li>站点活着且有正式域名 Make sure your site is alive with a formal domain</li>
    <li>
      至少五篇原创文章且最近一年更新过 At least 5 original articles and exists articles released in
      recent year
    </li>
    <li>内容不违反国家法律 Content does not violate laws</li>
  </ul>
</PageLayout>
