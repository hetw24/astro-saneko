---
import { Image } from 'astro:assets'

import { Quote } from 'astro-pure/advanced'
import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { Button, Card, Icon, Label } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import { buildBlogSlugMap } from '@/utils/blogSlug'
import ProjectCard from '@/components/home/ProjectCard.astro'
import Section from '@/components/home/Section.astro'
import SkillLayout from '@/components/home/SkillLayout.astro'
import config from '@/site-config'

const languages = ['Html', 'JavaScript', 'CSS', 'Shell']
const frontend = ['TypeScript', 'Vite', 'Webpack', 'Astro']
const backend = ['Vercel', 'Waline']

type WebsiteItem = {
  title: string
  description: string
  link: string
  image: string
}

const websiteList = (config as any).websiteList as WebsiteItem[] | undefined

const MAX_POSTS = 10
const allPosts = await getBlogCollection()
const allPostsByDate = sortMDByDate(allPosts)
const slugMap = Object.fromEntries(buildBlogSlugMap(allPostsByDate))
const recentPosts = allPostsByDate.slice(0, MAX_POSTS)

const imagePath = config.logo.src
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/*.{jpeg,jpg,png,gif,avif,webp}'
)
if (!images[imagePath])
  throw new Error(
    `"${imagePath}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif,avif,webp}"`
  )
---

<PageLayout meta={{ title: 'Home' }} highlightColor='#8C766D'>
  <main class='flex w-full flex-col items-center'>
    <section class='animate mb-10 flex flex-col items-center gap-y-7' id='content-header'>
      <Image
        src={images[imagePath]()}
        alt={config.logo.alt || 'Profile'}
        class='h-36 w-auto rounded-full border p-1 avatar-glow'
        loading='eager'
        fetchpriority='high'
      />

      <div class='flex flex-col items-center gap-y-4'>
        <h1 class='text-4xl font-medium'>{config.author}</h1>
        <div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
          <Label title={config.home?.location ?? 'Somewhere'}>
            <Icon name='location' class='size-5' slot='icon' />
          </Label>
          {
            config.footer.social &&
              Object.keys(config.footer.social).map((key) => {
                if (key === 'github') return
                const social = config.footer.social
                if (!social) return
                const link = social[key as keyof typeof social]
                
                // 抖音（tiktok）点击时复制 ID 而不是跳转
                if (key === 'tiktok' && link) {
                  // 从链接中提取 ID（支持数字 ID 和用户名）
                  const idMatch = link.match(/douyin\.com\/user\/([^/]+)/)
                  const id = idMatch?.[1]
                  if (id) {
                    const copyScript = `
                      event.preventDefault();
                      navigator.clipboard.writeText('${id}');
                      document.dispatchEvent(new CustomEvent('toast', {
                        detail: { message: '已复制 ID: ${id}' }
                      }));
                    `
                    return (
                      <Label
                        title='Douyin'
                        as='a'
                        href='#'
                        onclick={copyScript}
                      >
                        <Icon name={key as any} class='size-5' slot='icon' />
                      </Label>
                    )
                  }
                }
                
                return (
                  <Label
                    title={key.charAt(0).toUpperCase() + key.slice(1)}
                    as='a'
                    href={link}
                    target='_blank'
                  >
                    <Icon name={key as any} class='size-5' slot='icon' />
                  </Label>
                )
              })
          }
          {
            config.footer.social?.github && (
              <Label
                as='a'
                href={config.footer.social.github}
                target='_blank'
                title='Github'
              >
                <Icon name='github' class='size-5' slot='icon' />
              </Label>
            )
          }
        </div>
      </div>
    </section>

    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      <Section title='About'>
        {
          config.footer.about && (
            <>
              <p class='text-muted-foreground'>{config.footer.about.intro}</p>
              <p class='text-muted-foreground'>{config.footer.about.bio}</p>
            </>
          )
        }
        <Button title='More about me' class='w-fit self-end' href='/about' variant='ahead' />
      </Section>
      {
        recentPosts.length > 0 && (
          <Section title='Posts'>
            <ul class='flex flex-col gap-y-1.5 sm:gap-y-2'>
              {recentPosts.map((p) => (
                <li class='flex flex-col gap-x-2 sm:flex-row'>
                  <PostPreview post={p} slugMap={slugMap} />
                </li>
              ))}
            </ul>
            <Button title='More posts' class='w-fit self-end' href='/blog' variant='ahead' />
          </Section>
        )
      }

      {
        /* <Section title='Experience'>
      <Card
        heading='Lorem Ipsum'
        subheading='Sit amet consectetur'
        date='Dec 2022 - Nov 2023'
        imagePath='/src/assets/about-astro.png'
        altText='Lorem, ipsum dolor sit'
        imageClass='h-12 w-auto md:-start-16'
      >
        <ul class='ms-4 list-disc text-muted-foreground'>
          <li>
            Lorem, ipsum dolor sit amet consectetur adipisicing elit. Dolore debitis recusandae, ut
            molestiae laboriosam pariatur!

            <li>Lorem ipsum dolor sit amet consectetur adipisicing elit. Molestiae, pariatur!</li>
          </li>
        </ul>
      </Card>
      <Card
        heading='Lorem Ipsum'
        subheading='Sit amet consectetur'
        date='Dec 2022 - Nov 2023'
        imagePath='/src/assets/about-astro.png'
        altText='Lorem, ipsum dolor sit'
        imageClass='h-12 w-auto md:-start-16'
      />
    </Section> */
      }

      {
        websiteList && websiteList.length > 0 && (
          <Section title='Projects'>
            <div class='grid grid-cols-1 gap-3 sm:grid-cols-2'>
              {
                websiteList.map((item: WebsiteItem) => (
                  <ProjectCard
                    href={item.link}
                    heading={item.title}
                    subheading={item.description}
                    imagePath={item.image}
                  />
                ))
              }
            </div>
            <Button title='More projects' class='w-fit self-end' href='/projects' variant='ahead' />
          </Section>
        )
      }
    </div>
    <Quote class='mt-12' />
  </main>
</PageLayout>
